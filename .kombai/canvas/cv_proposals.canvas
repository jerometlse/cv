      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Lora:ital,wght@0,400;0,700;1,400&display=swap');\n\n  :root {\n    --old-lace: #FDF5E6;\n    --night-bordeaux: #58111A;\n    --camel: #C19A6B;\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Lora', serif;\n    color: var(--night-bordeaux);\n    background-color: var(--old-lace);\n    overflow-x: hidden;\n  }\n\n  .font-playfair { font-family: 'Playfair Display', serif; }\n  .font-lora { font-family: 'Lora', serif; }\n\n  .paper-texture {\n    background-image: url('https://images.unsplash.com/photo-1603513492128-ba7bc9b3e143?auto=format&w=1440&q=80&fit=crop');\n    background-blend-mode: multiply;\n    background-size: cover;\n    background-attachment: fixed;\n  }\n\n  .hairline-y {\n    border-top: 1px solid rgba(88, 17, 26, 0.2);\n    border-bottom: 1px solid rgba(88, 17, 26, 0.2);\n  }\n\n  .fleur-de-lys {\n    width: 28px;\n    height: 28px;\n    filter: brightness(0) saturate(100%) invert(13%) sepia(35%) saturate(4521%) hue-rotate(336deg) brightness(89%) contrast(98%);\n  }\n\n  .fleur-de-lys-camel {\n    filter: brightness(0) saturate(100%) invert(64%) sepia(21%) saturate(763%) hue-rotate(352deg) brightness(91%) contrast(85%);\n  }\n\n  .swiss-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    border-top: 1px solid var(--night-bordeaux);\n    border-left: 1px solid var(--night-bordeaux);\n  }\n\n  .swiss-cell {\n    border-right: 1px solid var(--night-bordeaux);\n    border-bottom: 1px solid var(--night-bordeaux);\n    padding: 2.5rem;\n    transition: background-color 0.4s ease;\n  }\n\n  .swiss-cell:hover {\n    background-color: rgba(88, 17, 26, 0.03);\n  }\n\n  .tech-pill {\n    font-size: 10px;\n    padding: 3px 8px;\n    border: 1px solid rgba(88, 17, 26, 0.15);\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    margin-right: 6px;\n    margin-bottom: 6px;\n    display: inline-block;\n    color: var(--night-bordeaux);\n    background: rgba(193, 154, 107, 0.05);\n  }\n\n  .section-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 11px;\n    text-transform: uppercase;\n    letter-spacing: 0.4em;\n    color: var(--camel);\n    margin-bottom: 1rem;\n    font-weight: 700;\n  }\n\n  .magazine-split {\n    height: 800px;\n  }\n\n  @media (max-width: 768px) {\n    .magazine-split {\n      height: auto;\n    }\n  }\n</style>\n\n<div class=\"paper-texture\" data-kid=\"1\">\n  \n  <section class=\"magazine-split flex flex-col md:flex-row border-b-[6px] border-[var(--night-bordeaux)]\" data-kid=\"2\">\n    \n    <div class=\"md:w-1/2 bg-[var(--night-bordeaux)] relative overflow-hidden flex items-center justify-center\" data-kid=\"3\">\n      <img src=\"/api/local/images/portrait.jpg\" alt=\"Jérôme Capelle\" class=\"w-full h-full object-cover grayscale contrast-105 brightness-110 mix-blend-luminosity opacity-95\" data-kid=\"4\">\n      <div class=\"absolute bottom-12 left-12 flex items-center gap-4 text-[var(--old-lace)]/40\" data-kid=\"5\">\n        <div class=\"h-[1px] w-12 bg-current\" data-kid=\"6\"></div>\n        <span class=\"text-[10px] tracking-[0.5em] uppercase font-bold\" data-kid=\"7\">EST. 2006 — VOLUME 15</span>\n      </div>\n    </div>\n\n    \n    <div class=\"md:w-1/2 bg-[var(--old-lace)] p-12 md:p-20 flex flex-col justify-between relative\" data-kid=\"8\">\n      <div class=\"border-b border-[var(--night-bordeaux)] pb-6 flex justify-between items-center mb-12\" data-kid=\"9\">\n        <span class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-70\" data-kid=\"10\">L'Édition Spéciale</span>\n        <span class=\"text-[10px] tracking-[0.4em] uppercase font-bold text-right opacity-70\" data-kid=\"11\">Ingénieur Full Stack</span>\n      </div>\n\n      <div class=\"mb-auto\" data-kid=\"12\">\n        <h1 class=\"font-playfair text-[5rem] md:text-[7rem] lg:text-[8.5rem] leading-[0.8] font-black tracking-tighter mb-10 text-[var(--night-bordeaux)] whitespace-nowrap\" data-kid=\"13\">\n          Jérôme<br data-kid=\"14\">CAPELLE\n        </h1>\n        \n        <div class=\"flex items-center gap-6 mb-16\" data-kid=\"15\">\n          <div class=\"w-16 h-[2px] bg-[var(--camel)]\" data-kid=\"16\"></div>\n          <p class=\"font-playfair italic text-3xl md:text-4xl text-[var(--camel)]\" data-kid=\"17\">\n            Architecte du Web Moderne\n          </p>\n        </div>\n\n        <div class=\"grid grid-cols-2 gap-10 text-[12px] uppercase tracking-widest leading-relaxed\" data-kid=\"18\">\n          <div class=\"space-y-2\" data-kid=\"19\">\n            <h4 class=\"font-bold text-[var(--camel)] opacity-80\" data-kid=\"20\">Localisation</h4>\n            <p data-kid=\"21\">Gragnague (31)</p>\n            <p data-kid=\"22\">Région Toulousaine</p>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"23\">\n            <h4 class=\"font-bold text-[var(--camel)] opacity-80\" data-kid=\"24\">Contact</h4>\n            <p data-kid=\"25\">06 16 49 40 25</p>\n            <p class=\"lowercase\" data-kid=\"26\">jerome.capelle@gmail.com</p>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"27\">\n            <h4 class=\"font-bold text-[var(--camel)] opacity-80\" data-kid=\"28\">Détails</h4>\n            <p data-kid=\"29\">50 Ans • Permis B</p>\n          </div>\n          <div class=\"flex items-end justify-end\" data-kid=\"30\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"fleur-de-lys opacity-20\" data-kid=\"31\">\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex justify-between items-end mt-12\" data-kid=\"32\">\n        <div class=\"text-[10px] opacity-40 uppercase tracking-widest font-bold\" data-kid=\"33\">French Elegance Series</div>\n        <div class=\"font-playfair italic text-6xl opacity-10\" data-kid=\"34\">01</div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 md:px-24 max-w-7xl mx-auto\" data-kid=\"35\">\n    <div class=\"flex flex-col items-center text-center\" data-kid=\"36\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"fleur-de-lys mb-16 opacity-60\" data-kid=\"37\">\n      \n      <div class=\"hairline-y py-20 relative px-4 md:px-20 max-w-4xl\" data-kid=\"38\">\n        <blockquote class=\"font-playfair italic text-2xl md:text-4xl lg:text-5xl leading-[1.4] text-[var(--night-bordeaux)]\" data-kid=\"39\">\n          “Expert avec 15 ans d'expérience dans la conception d’applications web critiques. Spécialisé en architectures backend (Django, Symfony) et interfaces modernes (Vue.js, Nuxt) pour de grands comptes.”\n        </blockquote>\n      </div>\n      \n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"fleur-de-lys mt-16 rotate-180\" data-kid=\"40\">\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[var(--night-bordeaux)] text-[var(--old-lace)] py-32 px-12 md:px-24\" data-kid=\"41\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"42\">\n      <div class=\"flex flex-col md:flex-row gap-20\" data-kid=\"43\">\n        \n        <div class=\"flex-1 space-y-10\" data-kid=\"44\">\n          <div class=\"flex items-center gap-4\" data-kid=\"45\">\n            <div class=\"w-12 h-[1px] bg-[var(--camel)]\" data-kid=\"46\"></div>\n            <span class=\"text-[10px] tracking-[0.6em] uppercase font-black text-[var(--camel)]\" data-kid=\"47\">Backend Expertise</span>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"48\">\n            <h3 class=\"font-playfair text-5xl\" data-kid=\"49\">Django & Symfony</h3>\n            <p class=\"font-lora text-lg leading-relaxed opacity-70\" data-kid=\"50\">Conception d'architectures robustes avec Python et PHP (Symfony 3/4). Gestion de flux critiques et de back-offices complexes.</p>\n            <div class=\"flex flex-wrap gap-3 pt-4\" data-kid=\"51\">\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"52\">Python</span>\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"53\">PHP</span>\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"54\">REST APIs</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 space-y-10\" data-kid=\"55\">\n          <div class=\"flex items-center gap-4\" data-kid=\"56\">\n            <div class=\"w-12 h-[1px] bg-[var(--camel)]\" data-kid=\"57\"></div>\n            <span class=\"text-[10px] tracking-[0.6em] uppercase font-black text-[var(--camel)]\" data-kid=\"58\">Frontend Artistry</span>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"59\">\n            <h3 class=\"font-playfair text-5xl\" data-kid=\"60\">Vue.js & Nuxt</h3>\n            <p class=\"font-lora text-lg leading-relaxed opacity-70\" data-kid=\"61\">Création d'interfaces réactives et modernes. Maîtrise d'Angular, Tailwind CSS et des frameworks d'UI haut de gamme.</p>\n            <div class=\"flex flex-wrap gap-3 pt-4\" data-kid=\"62\">\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"63\">Vue 3</span>\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"64\">Angular</span>\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"65\">Tailwind</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 space-y-10\" data-kid=\"66\">\n          <div class=\"flex items-center gap-4\" data-kid=\"67\">\n            <div class=\"w-12 h-[1px] bg-[var(--camel)]\" data-kid=\"68\"></div>\n            <span class=\"text-[10px] tracking-[0.6em] uppercase font-black text-[var(--camel)]\" data-kid=\"69\">Data & Cloud</span>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"70\">\n            <h3 class=\"font-playfair text-5xl\" data-kid=\"71\">GCP & SQL</h3>\n            <p class=\"font-lora text-lg leading-relaxed opacity-70\" data-kid=\"72\">Maîtrise de l'écosystème Google Cloud. Gestion de bases de données PostgreSQL, MSSQL et ETL Talend.</p>\n            <div class=\"flex flex-wrap gap-3 pt-4\" data-kid=\"73\">\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"74\">PostgreSQL</span>\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"75\">Docker</span>\n              <span class=\"text-[10px] uppercase tracking-widest font-black text-[var(--camel)] px-2 py-1 border border-[var(--camel)]/30\" data-kid=\"76\">GCP APIs</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"border-t-[1px] border-[var(--night-bordeaux)]\" data-kid=\"77\">\n    \n    <div class=\"bg-[var(--old-lace)] py-24 px-12 md:px-24\" data-kid=\"78\">\n      <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row gap-20 items-start\" data-kid=\"79\">\n        <div class=\"md:w-2/5\" data-kid=\"80\">\n          <div class=\"text-[var(--camel)] font-black text-[10px] tracking-[0.4em] mb-4 uppercase\" data-kid=\"81\">2020 — Présent</div>\n          <h2 class=\"font-playfair text-6xl lg:text-7xl mb-4 text-[var(--night-bordeaux)]\" data-kid=\"82\">CCL Consulting</h2>\n          <p class=\"font-lora italic text-2xl text-[var(--camel)] mb-8\" data-kid=\"83\">Ingénieur Full Stack</p>\n          <div class=\"h-[1px] w-24 bg-[var(--night-bordeaux)] opacity-20\" data-kid=\"84\"></div>\n        </div>\n        <div class=\"md:w-3/5 space-y-16\" data-kid=\"85\">\n          <div class=\"space-y-4\" data-kid=\"86\">\n            <h4 class=\"font-playfair text-2xl font-bold uppercase tracking-tight\" data-kid=\"87\">Safran Ventilation Systems</h4>\n            <p class=\"font-lora text-lg leading-relaxed opacity-80\" data-kid=\"88\">Développement d'une application critique permettant de calculer la fiabilité des équipements aéronautiques.</p>\n            <div class=\"flex flex-wrap pt-2\" data-kid=\"89\">\n              <span class=\"tech-pill\" data-kid=\"90\">Python</span><span class=\"tech-pill\" data-kid=\"91\">Django</span><span class=\"tech-pill\" data-kid=\"92\">VueJs</span><span class=\"tech-pill\" data-kid=\"93\">Nuxt</span><span class=\"tech-pill\" data-kid=\"94\">PostgresSQL</span>\n            </div>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"95\">\n            <h4 class=\"font-playfair text-2xl font-bold uppercase tracking-tight\" data-kid=\"96\">Airbus (G Suite Lifecycle)</h4>\n            <p class=\"font-lora text-lg leading-relaxed opacity-80\" data-kid=\"97\">Automatisation et gestion du cycle de vie des comptes collaborateurs. Architecture complexe intégrant les Google APIs et RabbitMQ.</p>\n            <div class=\"flex flex-wrap pt-2\" data-kid=\"98\">\n              <span class=\"tech-pill\" data-kid=\"99\">Python</span><span class=\"tech-pill\" data-kid=\"100\">Django</span><span class=\"tech-pill\" data-kid=\"101\">MSSQL</span><span class=\"tech-pill\" data-kid=\"102\">Angular</span><span class=\"tech-pill\" data-kid=\"103\">RabbitMQ</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-white py-24 px-12 md:px-24 border-y border-[var(--night-bordeaux)]\" data-kid=\"104\">\n      <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row-reverse gap-20 items-start text-right md:text-left\" data-kid=\"105\">\n        <div class=\"md:w-2/5 md:text-right\" data-kid=\"106\">\n          <div class=\"text-[var(--camel)] font-black text-[10px] tracking-[0.4em] mb-4 uppercase\" data-kid=\"107\">2017 — 2020</div>\n          <h2 class=\"font-playfair text-6xl lg:text-7xl mb-4 text-[var(--night-bordeaux)]\" data-kid=\"108\">Décsoft</h2>\n          <p class=\"font-lora italic text-2xl text-[var(--camel)] mb-8\" data-kid=\"109\">Ingénieur d'études</p>\n          <div class=\"flex justify-end md:justify-end\" data-kid=\"110\"><div class=\"h-[1px] w-24 bg-[var(--night-bordeaux)] opacity-20\" data-kid=\"111\"></div></div>\n        </div>\n        <div class=\"md:w-3/5 space-y-16 text-left\" data-kid=\"112\">\n          <div class=\"space-y-4\" data-kid=\"113\">\n            <h4 class=\"font-playfair text-2xl font-bold uppercase tracking-tight\" data-kid=\"114\">Airbus & Partenaires</h4>\n            <p class=\"font-lora text-lg leading-relaxed opacity-80\" data-kid=\"115\">Développement et maintenance de l'écosystème web pour des clients grands comptes. Focus sur la robustesse et la scalabilité.</p>\n            <div class=\"flex flex-wrap pt-2\" data-kid=\"116\">\n              <span class=\"tech-pill\" data-kid=\"117\">PHP</span><span class=\"tech-pill\" data-kid=\"118\">Symfony 3</span><span class=\"tech-pill\" data-kid=\"119\">RabbitMQ</span><span class=\"tech-pill\" data-kid=\"120\">Angular</span><span class=\"tech-pill\" data-kid=\"121\">Django</span>\n            </div>\n          </div>\n          <div class=\"space-y-4 opacity-60\" data-kid=\"122\">\n            <h4 class=\"font-playfair text-xl font-bold uppercase\" data-kid=\"123\">WS-Interactive</h4>\n            <p class=\"font-lora text-md leading-relaxed\" data-kid=\"124\">Maintenance de sites e-commerce et institutionnels.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-[var(--old-lace)] py-24 px-12 md:px-24\" data-kid=\"125\">\n      <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row gap-20 items-start\" data-kid=\"126\">\n        <div class=\"md:w-2/5\" data-kid=\"127\">\n          <div class=\"text-[var(--camel)] font-black text-[10px] tracking-[0.4em] mb-4 uppercase\" data-kid=\"128\">2010 — 2017</div>\n          <h2 class=\"font-playfair text-6xl lg:text-7xl mb-4 text-[var(--night-bordeaux)]\" data-kid=\"129\">Celad</h2>\n          <p class=\"font-lora italic text-2xl text-[var(--camel)] mb-8\" data-kid=\"130\">Ingénieur Développement</p>\n          <div class=\"h-[1px] w-24 bg-[var(--night-bordeaux)] opacity-20\" data-kid=\"131\"></div>\n        </div>\n        <div class=\"md:w-3/5 space-y-16\" data-kid=\"132\">\n          <div class=\"space-y-4\" data-kid=\"133\">\n            <h4 class=\"font-playfair text-2xl font-bold uppercase tracking-tight\" data-kid=\"134\">FRAM (Voyages)</h4>\n            <p class=\"font-lora text-lg leading-relaxed opacity-80\" data-kid=\"135\">Plateformes B2B/B2C massives. Réalisation de back-offices complexes sous Symfony et gestion de flux via Talend ETL.</p>\n            <div class=\"flex flex-wrap pt-2\" data-kid=\"136\">\n              <span class=\"tech-pill\" data-kid=\"137\">PHP</span><span class=\"tech-pill\" data-kid=\"138\">Symfony 1.4/2</span><span class=\"tech-pill\" data-kid=\"139\">Talend</span><span class=\"tech-pill\" data-kid=\"140\">JQuery</span><span class=\"tech-pill\" data-kid=\"141\">DB2</span>\n            </div>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"142\">\n            <h4 class=\"font-playfair text-2xl font-bold uppercase tracking-tight\" data-kid=\"143\">Europa Organisation</h4>\n            <p class=\"font-lora text-lg leading-relaxed opacity-80\" data-kid=\"144\">Application de gestion hôtelière critique pour événements internationaux.</p>\n            <div class=\"flex flex-wrap pt-2\" data-kid=\"145\">\n              <span class=\"tech-pill\" data-kid=\"146\">Symfony 2</span><span class=\"tech-pill\" data-kid=\"147\">AngularJS</span><span class=\"tech-pill\" data-kid=\"148\">PostgreSQL</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-12 md:px-24 bg-white\" data-kid=\"149\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"150\">\n      <div class=\"flex justify-between items-end mb-16 border-b-2 border-[var(--night-bordeaux)] pb-8\" data-kid=\"151\">\n        <div data-kid=\"152\">\n          <h2 class=\"font-playfair text-7xl mb-4\" data-kid=\"153\">L'Éducation</h2>\n          <p class=\"font-lora italic text-xl opacity-60\" data-kid=\"154\">Parcours académique & certifications professionnelles</p>\n        </div>\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"fleur-de-lys mb-2\" data-kid=\"155\">\n      </div>\n\n      <div class=\"swiss-grid\" data-kid=\"156\">\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-4\" data-kid=\"157\">\n          <div class=\"section-title\" data-kid=\"158\">2021 — Toulouse</div>\n          <h3 class=\"font-playfair text-3xl mb-2\" data-kid=\"159\">Angular Framework</h3>\n          <p class=\"font-lora text-sm opacity-60 uppercase tracking-widest\" data-kid=\"160\">AELION Professional Training</p>\n        </div>\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-4\" data-kid=\"161\">\n          <div class=\"section-title\" data-kid=\"162\">2014 — Sensio Labs</div>\n          <h3 class=\"font-playfair text-3xl mb-2\" data-kid=\"163\">Symfony 2 Expert</h3>\n          <p class=\"font-lora text-sm opacity-60 uppercase tracking-widest\" data-kid=\"164\">Certification Spécialiste</p>\n        </div>\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-4\" data-kid=\"165\">\n          <div class=\"section-title\" data-kid=\"166\">2009 — Balma</div>\n          <h3 class=\"font-playfair text-3xl mb-2\" data-kid=\"167\">JAVA / J2EE</h3>\n          <p class=\"font-lora text-sm opacity-60 uppercase tracking-widest\" data-kid=\"168\">CRP Consulting</p>\n        </div>\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-6\" data-kid=\"169\">\n          <div class=\"section-title\" data-kid=\"170\">Personal Assets</div>\n          <div class=\"flex flex-wrap gap-8 py-4\" data-kid=\"171\">\n            <div class=\"space-y-1\" data-kid=\"172\">\n              <span class=\"font-playfair italic text-4xl block text-[var(--camel)]\" data-kid=\"173\">Adaptabilité</span>\n              <span class=\"text-[10px] uppercase tracking-widest opacity-40 font-bold\" data-kid=\"174\">Capacité de pivot</span>\n            </div>\n            <div class=\"space-y-1\" data-kid=\"175\">\n              <span class=\"font-playfair italic text-4xl block text-[var(--camel)]\" data-kid=\"176\">Rigueur</span>\n              <span class=\"text-[10px] uppercase tracking-widest opacity-40 font-bold\" data-kid=\"177\">Code de qualité</span>\n            </div>\n            <div class=\"space-y-1\" data-kid=\"178\">\n              <span class=\"font-playfair italic text-4xl block text-[var(--camel)]\" data-kid=\"179\">Perfectionnisme</span>\n              <span class=\"text-[10px] uppercase tracking-widest opacity-40 font-bold\" data-kid=\"180\">Souci du détail</span>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-6\" data-kid=\"181\">\n          <div class=\"section-title\" data-kid=\"182\">Languages</div>\n          <div class=\"grid grid-cols-2 gap-8 h-full items-center\" data-kid=\"183\">\n            <div class=\"border-l-2 border-[var(--camel)] pl-4\" data-kid=\"184\">\n              <span class=\"font-playfair text-3xl block\" data-kid=\"185\">Français</span>\n              <span class=\"text-[10px] uppercase tracking-widest opacity-50 font-bold\" data-kid=\"186\">Langue Maternelle</span>\n            </div>\n            <div class=\"border-l-2 border-[var(--night-bordeaux)]/20 pl-4\" data-kid=\"187\">\n              <span class=\"font-playfair text-3xl block\" data-kid=\"188\">Anglais</span>\n              <span class=\"text-[10px] uppercase tracking-widest opacity-50 font-bold\" data-kid=\"189\">Niveau Technique</span>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-8 bg-[var(--old-lace)]/40\" data-kid=\"190\">\n          <div class=\"section-title\" data-kid=\"191\">Academic Background</div>\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 py-4\" data-kid=\"192\">\n            <div class=\"space-y-2\" data-kid=\"193\">\n              <h4 class=\"font-playfair text-2xl\" data-kid=\"194\">Diplôme de Recherche Universitaire</h4>\n              <p class=\"font-lora text-sm opacity-70\" data-kid=\"195\">INP-ENSIACET — Lab Chimie Agro-industrielle (2001)</p>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"196\">\n              <h4 class=\"font-playfair text-2xl\" data-kid=\"197\">Maîtrise de Chimie</h4>\n              <p class=\"font-lora text-sm opacity-70\" data-kid=\"198\">Université Paul Sabatier Toulouse (2000)</p>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"swiss-cell col-span-12 md:col-span-4 flex items-center justify-center p-0 overflow-hidden\" data-kid=\"199\">\n          <div class=\"w-full h-full p-12 bg-[var(--night-bordeaux)] text-[var(--old-lace)] flex flex-col items-center justify-center text-center\" data-kid=\"200\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"fleur-de-lys-camel mb-6 w-16 h-16 opacity-50\" data-kid=\"201\">\n            <p class=\"font-playfair italic text-xl\" data-kid=\"202\">\"L'élégance est la seule beauté qui ne se fane jamais.\"</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-32 px-12 md:px-24 bg-[var(--night-bordeaux)] text-[var(--old-lace)] overflow-hidden relative\" data-kid=\"203\">\n    <div class=\"absolute -right-20 -bottom-20 opacity-[0.03] w-[700px] h-[700px]\" data-kid=\"204\">\n       <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"w-full h-full fleur-de-lys-camel\" data-kid=\"205\">\n    </div>\n    <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"206\">\n      <div class=\"flex flex-col md:flex-row justify-between items-center gap-16 border-b border-[var(--old-lace)]/10 pb-20\" data-kid=\"207\">\n        <div class=\"space-y-6 text-center md:text-left\" data-kid=\"208\">\n          <h2 class=\"font-playfair text-6xl md:text-7xl font-black tracking-tighter\" data-kid=\"209\">Jérôme CAPELLE</h2>\n          <div class=\"flex items-center justify-center md:justify-start gap-4\" data-kid=\"210\">\n             <div class=\"w-8 h-[1px] bg-[var(--camel)]\" data-kid=\"211\"></div>\n             <p class=\"font-lora italic text-xl opacity-70\" data-kid=\"212\">Senior Full Stack Engineer</p>\n          </div>\n        </div>\n        <div class=\"flex flex-wrap justify-center gap-8 md:gap-12 text-[10px] uppercase tracking-[0.5em] font-bold opacity-60\" data-kid=\"213\">\n          <a href=\"#\" class=\"hover:text-[var(--camel)] transition-colors\" data-kid=\"214\">LinkedIn</a>\n          <a href=\"#\" class=\"hover:text-[var(--camel)] transition-colors\" data-kid=\"215\">GitHub</a>\n          <a href=\"#\" class=\"hover:text-[var(--camel)] transition-colors\" data-kid=\"216\">Curriculum Vitae</a>\n        </div>\n      </div>\n      <div class=\"mt-12 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"217\">\n        <div class=\"text-[10px] opacity-30 uppercase tracking-widest\" data-kid=\"218\">\n          &copy; 2024 Jérôme Capelle. All rights reserved.\n        </div>\n        <div class=\"flex items-center gap-4 opacity-30\" data-kid=\"219\">\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/fleur-de-lys.svg\" class=\"w-4 h-4 fleur-de-lys-camel\" data-kid=\"220\">\n          <span class=\"text-[10px] uppercase tracking-widest\" data-kid=\"221\">Édition Limitée — Gragnague, FR</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n",
