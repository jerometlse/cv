      "html": "\n<div class=\"bg-[#001F3F] min-h-[1000px] text-cyan-50 font-['Fira_Sans'] relative overflow-hidden selection:bg-cyan-500/30\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-heading { font-family: 'Space Grotesk', sans-serif; }\n        \n        /* Glassmorphism */\n        .glass-card {\n            background: rgba(0, 51, 102, 0.4);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(0, 255, 255, 0.15);\n            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);\n        }\n\n        /* Neon Inset */\n        .neon-inset {\n            border: 1.5px solid #00FFFF;\n            background: #001F3F;\n            box-shadow: 0 0 15px rgba(0, 255, 255, 0.15), inset 0 0 30px rgba(0, 255, 255, 0.05);\n        }\n\n        /* Pulse Glow */\n        @keyframes pulse-glow {\n            0%, 100% { box-shadow: 0 0 5px rgba(0, 255, 255, 0.3); }\n            50% { box-shadow: 0 0 20px rgba(0, 255, 255, 0.6); }\n        }\n        .pulse-node {\n            animation: pulse-glow 2s infinite ease-in-out;\n        }\n\n        /* Custom Scrollbar (if any) */\n        ::-webkit-scrollbar { width: 8px; }\n        ::-webkit-scrollbar-track { background: #001F3F; }\n        ::-webkit-scrollbar-thumb { background: #003366; border-radius: 10px; }\n        ::-webkit-scrollbar-thumb:hover { background: #00FFFF; }\n\n        /* Timeline Gradient Spine */\n        .timeline-spine {\n            background: linear-gradient(to bottom, #00FFFF 0%, #00FFFF 80%, transparent 100%);\n        }\n\n        /* Masonry Support */\n        .masonry-grid {\n            display: grid;\n            grid-template-columns: repeat(1, minmax(0, 1fr));\n            gap: 1.5rem;\n        }\n        @media (min-width: 768px) {\n            .masonry-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }\n        }\n        @media (min-width: 1024px) {\n            .masonry-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }\n        }\n\n        /* Spotlights */\n        .hero-spotlight {\n            background: radial-gradient(circle at 50% 50%, rgba(0, 255, 255, 0.1) 0%, transparent 60%);\n        }\n    </style>\n\n    \n    <div class=\"absolute inset-0 pointer-events-none opacity-10 z-0\" data-kid=\"2\">\n        <img src=\"https://images.unsplash.com/photo-1644088379091-d574269d422f?auto=format&w=1920&q=80&fit=crop\" alt=\"Background Texture\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n    </div>\n\n    \n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"absolute top-20 left-10 w-40 h-40 opacity-5 invert brightness-0 pointer-events-none z-0\" data-kid=\"4\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/crosshair.svg\" class=\"absolute bottom-20 right-10 w-60 h-60 opacity-5 invert brightness-0 pointer-events-none z-0\" data-kid=\"5\">\n\n    <div class=\"max-w-6xl mx-auto px-6 py-12 pb-32 relative\" data-kid=\"6\">\n        \n        \n        <header class=\"relative mb-24 h-[600px] flex items-center justify-center\" data-kid=\"7\">\n            <div class=\"absolute inset-0 hero-spotlight pointer-events-none\" data-kid=\"8\"></div>\n            \n            <div class=\"glass-card w-full p-12 rounded-[40px] flex flex-col md:flex-row items-center gap-12 relative overflow-hidden\" data-kid=\"9\">\n                \n                <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"absolute -right-20 -top-20 w-80 h-80 opacity-10 invert brightness-0 pointer-events-none rotate-12\" data-kid=\"10\">\n                \n                <div class=\"relative shrink-0 z-20\" data-kid=\"11\">\n                    <div class=\"w-56 h-56 rounded-3xl overflow-hidden border-2 border-cyan-400 shadow-[0_0_25px_rgba(0,255,255,0.4)] bg-[#001F3F]/50\" data-kid=\"12\">\n                        <img src=\"/api/local/images/portrait.jpg\" alt=\"Jérôme CAPELLE\" class=\"w-full h-full object-cover grayscale brightness-125 contrast-110 hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"13\">\n                    </div>\n                    <div class=\"absolute -bottom-4 -right-4 w-12 h-12 bg-[#001F3F] rounded-xl flex items-center justify-center border border-cyan-500/30\" data-kid=\"14\">\n                        <i class=\"ti ti-target-arrow text-cyan-400 text-xl\" data-kid=\"15\"></i>\n                    </div>\n                </div>\n\n                <div class=\"flex-grow text-center md:text-left\" data-kid=\"16\">\n                    <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-cyan-500/20 bg-cyan-500/5 text-cyan-400 text-xs font-heading font-semibold tracking-widest uppercase mb-6\" data-kid=\"17\">\n                        <span class=\"w-2 h-2 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"18\"></span>\n                        Engineering Lead\n                    </div>\n                    <h1 class=\"text-6xl md:text-8xl font-heading font-bold text-white mb-4 tracking-tight\" data-kid=\"19\">\n                        Jérôme <span class=\"text-cyan-400\" data-kid=\"20\">CAPELLE</span>\n                    </h1>\n                    <p class=\"text-2xl text-cyan-100/60 font-light mb-10 max-w-2xl\" data-kid=\"21\">\n                        Architecting resilient full-stack ecosystems for over <span class=\"text-cyan-400 font-semibold\" data-kid=\"22\">15 years</span>.\n                    </p>\n                    \n                    <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4\" data-kid=\"23\">\n                        <a href=\"mailto:jerome.capelle@gmail.com\" class=\"flex flex-col items-start p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400/50 transition-colors group\" data-kid=\"24\">\n                            <i class=\"ti ti-mail text-cyan-400 mb-2 text-xl group-hover:scale-110 transition-transform\" data-kid=\"25\"></i>\n                            <span class=\"text-[10px] uppercase tracking-wider text-cyan-100/40\" data-kid=\"26\">Email</span>\n                            <span class=\"text-sm truncate w-full\" data-kid=\"27\">jerome.capelle@gmail.com</span>\n                        </a>\n                        <div class=\"flex flex-col items-start p-4 rounded-2xl bg-white/5 border border-white/10\" data-kid=\"28\">\n                            <i class=\"ti ti-phone text-cyan-400 mb-2 text-xl\" data-kid=\"29\"></i>\n                            <span class=\"text-[10px] uppercase tracking-wider text-cyan-100/40\" data-kid=\"30\">Phone</span>\n                            <span class=\"text-sm\" data-kid=\"31\">06 16 49 40 25</span>\n                        </div>\n                        <div class=\"flex flex-col items-start p-4 rounded-2xl bg-white/5 border border-white/10\" data-kid=\"32\">\n                            <i class=\"ti ti-map-pin text-cyan-400 mb-2 text-xl\" data-kid=\"33\"></i>\n                            <span class=\"text-[10px] uppercase tracking-wider text-cyan-100/40\" data-kid=\"34\">Location</span>\n                            <span class=\"text-sm\" data-kid=\"35\">Gragnague (31)</span>\n                        </div>\n                        <div class=\"flex flex-col items-start p-4 rounded-2xl bg-white/5 border border-white/10\" data-kid=\"36\">\n                            <i class=\"ti ti-id text-cyan-400 mb-2 text-xl\" data-kid=\"37\"></i>\n                            <span class=\"text-[10px] uppercase tracking-wider text-cyan-100/40\" data-kid=\"38\">Profile</span>\n                            <span class=\"text-sm\" data-kid=\"39\">50 Years • Permis B</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </header>\n\n        \n        <section class=\"mb-32 relative group\" data-kid=\"40\">\n            <div class=\"absolute -left-20 -right-20 h-px bg-cyan-500/10 top-0 group-hover:bg-cyan-500/30 transition-colors\" data-kid=\"41\"></div>\n            <div class=\"absolute -left-20 -right-20 h-px bg-cyan-500/10 bottom-0 group-hover:bg-cyan-500/30 transition-colors\" data-kid=\"42\"></div>\n            <div class=\"absolute inset-0 bg-cyan-500/[0.02] -mx-20 pointer-events-none\" data-kid=\"43\"></div>\n            <div class=\"py-20 px-12 -mx-12 md:mx-0\" data-kid=\"44\">\n                <div class=\"max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-12\" data-kid=\"45\">\n                    <div class=\"shrink-0 relative\" data-kid=\"46\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/crosshair.svg\" class=\"w-32 h-32 opacity-20 invert brightness-0\" data-kid=\"47\">\n                        <div class=\"absolute inset-0 bg-cyan-400/20 blur-2xl rounded-full scale-50\" data-kid=\"48\"></div>\n                    </div>\n                    <blockquote class=\"text-3xl md:text-4xl font-heading font-light leading-snug text-cyan-100 italic relative\" data-kid=\"49\">\n                        \"Expert with 15 years of experience in the design of <span class=\"text-cyan-400 font-medium\" data-kid=\"50\">critical web applications</span>. Specializing in robust backend architectures (Django, Symfony) and modern frontend interfaces (Vue.js, Nuxt) for <span class=\"text-cyan-400 font-medium underline decoration-cyan-400/30 underline-offset-8\" data-kid=\"51\">major accounts</span>.\"\n                    </blockquote>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"mb-32\" data-kid=\"52\">\n            <h2 class=\"text-4xl font-heading font-bold text-white mb-12 flex items-center gap-4\" data-kid=\"53\">\n                <i class=\"ti ti-bolt text-cyan-400\" data-kid=\"54\"></i> Tech Stack Matrix\n            </h2>\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6\" data-kid=\"55\">\n                \n                <div class=\"md:col-span-2 md:row-span-2 neon-inset rounded-[32px] p-10 flex flex-col justify-between group\" data-kid=\"56\">\n                    <div data-kid=\"57\">\n                        <div class=\"w-16 h-16 rounded-2xl bg-cyan-500/10 flex items-center justify-center mb-8 border border-cyan-500/20 group-hover:border-cyan-400 transition-colors\" data-kid=\"58\">\n                            <i class=\"ti ti-database text-4xl text-cyan-400\" data-kid=\"59\"></i>\n                        </div>\n                        <h3 class=\"text-4xl font-heading font-bold text-white mb-6\" data-kid=\"60\">Backend Architect</h3>\n                        <p class=\"text-lg text-cyan-100/60 leading-relaxed mb-8\" data-kid=\"61\">\n                            High-concurrency systems using Python (Django) and PHP (Symfony 3/4). Expert in API design and complex business logic implementation.\n                        </p>\n                    </div>\n                    <div class=\"flex flex-wrap gap-3\" data-kid=\"62\">\n                        <span class=\"px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-sm text-cyan-300\" data-kid=\"63\">Django</span>\n                        <span class=\"px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-sm text-cyan-300\" data-kid=\"64\">Symfony</span>\n                        <span class=\"px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-sm text-cyan-300\" data-kid=\"65\">FastAPI</span>\n                        <span class=\"px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-sm text-cyan-300\" data-kid=\"66\">RabbitMQ</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass-card rounded-[32px] p-8 hover:bg-white/5 transition-colors\" data-kid=\"67\">\n                    <i class=\"ti ti-layout-board text-3xl text-cyan-400 mb-6 block\" data-kid=\"68\"></i>\n                    <h4 class=\"text-xl font-heading font-bold text-white mb-3\" data-kid=\"69\">Frontend</h4>\n                    <p class=\"text-sm text-cyan-100/50 mb-6\" data-kid=\"70\">Modern SPAs & SSR.</p>\n                    <ul class=\"space-y-2 text-sm\" data-kid=\"71\">\n                        <li class=\"flex items-center gap-2\" data-kid=\"72\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"73\"></i> Vue.js / Nuxt</li>\n                        <li class=\"flex items-center gap-2\" data-kid=\"74\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"75\"></i> Angular</li>\n                        <li class=\"flex items-center gap-2\" data-kid=\"76\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"77\"></i> Tailwind CSS</li>\n                    </ul>\n                </div>\n\n                \n                <div class=\"glass-card rounded-[32px] p-8 hover:bg-white/5 transition-colors\" data-kid=\"78\">\n                    <i class=\"ti ti-table text-3xl text-cyan-400 mb-6 block\" data-kid=\"79\"></i>\n                    <h4 class=\"text-xl font-heading font-bold text-white mb-3\" data-kid=\"80\">Data Science</h4>\n                    <p class=\"text-sm text-cyan-100/50 mb-6\" data-kid=\"81\">Storage & ETL pipeline.</p>\n                    <ul class=\"space-y-2 text-sm\" data-kid=\"82\">\n                        <li class=\"flex items-center gap-2\" data-kid=\"83\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"84\"></i> PostgreSQL</li>\n                        <li class=\"flex items-center gap-2\" data-kid=\"85\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"86\"></i> MSSQL / MariaDB</li>\n                        <li class=\"flex items-center gap-2\" data-kid=\"87\"><i class=\"ti ti-circle-check text-cyan-500\" data-kid=\"88\"></i> Talend ETL</li>\n                    </ul>\n                </div>\n\n                \n                <div class=\"md:col-span-2 glass-card rounded-[32px] p-8 flex items-center gap-8 hover:bg-white/5 transition-colors\" data-kid=\"89\">\n                    <div class=\"w-20 h-20 rounded-2xl bg-cyan-500/10 flex items-center justify-center shrink-0 border border-cyan-500/10\" data-kid=\"90\">\n                        <i class=\"ti ti-cloud-storm text-4xl text-cyan-400\" data-kid=\"91\"></i>\n                    </div>\n                    <div data-kid=\"92\">\n                        <h4 class=\"text-2xl font-heading font-bold text-white mb-2\" data-kid=\"93\">Cloud & DevOps</h4>\n                        <p class=\"text-cyan-100/60\" data-kid=\"94\">\n                            GCP infrastructure, Docker containerization, and G Suite API automation.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"mb-32\" data-kid=\"95\">\n            <h2 class=\"text-4xl font-heading font-bold text-white mb-16 flex items-center gap-4\" data-kid=\"96\">\n                <i class=\"ti ti-timeline text-cyan-400\" data-kid=\"97\"></i> Professional Journey\n            </h2>\n            \n            <div class=\"relative pl-20\" data-kid=\"98\">\n                \n                <div class=\"absolute left-[24px] top-4 bottom-0 w-[3px] timeline-spine\" data-kid=\"99\"></div>\n\n                \n                <div class=\"space-y-16\" data-kid=\"100\">\n                    \n                    \n                    <div class=\"relative group\" data-kid=\"101\">\n                        <div class=\"absolute -left-[68px] top-2 w-7 h-7 rounded-full bg-[#001F3F] border-[3px] border-cyan-400 pulse-node z-10\" data-kid=\"102\"></div>\n                        <div class=\"glass-card rounded-3xl p-8 hover:border-cyan-400/40 transition-all ml-4\" data-kid=\"103\">\n                            <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6\" data-kid=\"104\">\n                                <div data-kid=\"105\">\n                                    <h3 class=\"text-2xl font-heading font-bold text-white tracking-wide\" data-kid=\"106\">CCL CONSULTING</h3>\n                                    <p class=\"text-cyan-400 font-medium\" data-kid=\"107\">Ingénieur Full Stack</p>\n                                </div>\n                                <span class=\"px-4 py-1.5 rounded-full bg-cyan-500/10 text-cyan-400 text-sm font-semibold border border-cyan-500/20\" data-kid=\"108\">2020 – PRESENT</span>\n                            </div>\n                            <div class=\"grid md:grid-cols-2 gap-8\" data-kid=\"109\">\n                                <ul class=\"space-y-4\" data-kid=\"110\">\n                                    <li class=\"flex gap-4\" data-kid=\"111\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"112\"></i>\n                                        <span data-kid=\"113\"><strong class=\"text-white\" data-kid=\"114\">Safran Ventilation Systems:</strong> Dev of mission-critical reliability calculation apps.</span>\n                                    </li>\n                                    <li class=\"flex gap-4\" data-kid=\"115\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"116\"></i>\n                                        <span data-kid=\"117\"><strong class=\"text-white\" data-kid=\"118\">Guidap:</strong> Maintenance & evolution of activity booking platforms.</span>\n                                    </li>\n                                    <li class=\"flex gap-4\" data-kid=\"119\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"120\"></i>\n                                        <span data-kid=\"121\"><strong class=\"text-white\" data-kid=\"122\">Airbus:</strong> G Suite lifecycle automation & user management.</span>\n                                    </li>\n                                </ul>\n                                <div class=\"bg-cyan-950/40 rounded-2xl p-6 border border-cyan-500/10\" data-kid=\"123\">\n                                    <h4 class=\"text-xs uppercase tracking-widest text-cyan-400 mb-3 font-heading font-bold\" data-kid=\"124\">Tech Stack</h4>\n                                    <p class=\"text-xs text-cyan-100 leading-relaxed font-mono\" data-kid=\"125\">\n                                        Python, Django, Vue.js, Nuxt, Tailwind CSS, PostgreSQL, PHP, Symfony, Docker, Google Cloud APIs.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative group\" data-kid=\"126\">\n                        <div class=\"absolute -left-[68px] top-2 w-7 h-7 rounded-full bg-[#001F3F] border-[3px] border-cyan-600/50 z-10\" data-kid=\"127\"></div>\n                        <div class=\"glass-card rounded-3xl p-8 hover:border-cyan-400/40 transition-all ml-4\" data-kid=\"128\">\n                            <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6\" data-kid=\"129\">\n                                <div data-kid=\"130\">\n                                    <h3 class=\"text-2xl font-heading font-bold text-white tracking-wide\" data-kid=\"131\">DÉCASOFT</h3>\n                                    <p class=\"text-cyan-400 font-medium\" data-kid=\"132\">Ingénieur d'études</p>\n                                </div>\n                                <span class=\"px-4 py-1.5 rounded-full bg-white/5 text-cyan-100/60 text-sm font-semibold border border-white/10\" data-kid=\"133\">2017 – 2020</span>\n                            </div>\n                            <div class=\"grid md:grid-cols-2 gap-8\" data-kid=\"134\">\n                                <ul class=\"space-y-4\" data-kid=\"135\">\n                                    <li class=\"flex gap-4\" data-kid=\"136\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"137\"></i>\n                                        <span data-kid=\"138\"><strong class=\"text-white\" data-kid=\"139\">Airbus:</strong> Full-cycle web maintenance and client portal development.</span>\n                                    </li>\n                                    <li class=\"flex gap-4\" data-kid=\"140\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"141\"></i>\n                                        <span data-kid=\"142\"><strong class=\"text-white\" data-kid=\"143\">WS-Interactive:</strong> Custom PHP development and CMS maintenance.</span>\n                                    </li>\n                                </ul>\n                                <div class=\"bg-cyan-950/40 rounded-2xl p-6 border border-cyan-500/10\" data-kid=\"144\">\n                                    <h4 class=\"text-xs uppercase tracking-widest text-cyan-400 mb-3 font-heading font-bold\" data-kid=\"145\">Tech Stack</h4>\n                                    <p class=\"text-xs text-cyan-100 leading-relaxed font-mono\" data-kid=\"146\">\n                                        PHP, Symfony 3, Python, Django, MSSQL, RabbitMQ, Angular, TypeScript, Git.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative group\" data-kid=\"147\">\n                        <div class=\"absolute -left-[68px] top-2 w-7 h-7 rounded-full bg-[#001F3F] border-[3px] border-cyan-600/30 z-10\" data-kid=\"148\"></div>\n                        <div class=\"glass-card rounded-3xl p-8 hover:border-cyan-400/40 transition-all ml-4 opacity-80 hover:opacity-100\" data-kid=\"149\">\n                            <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6\" data-kid=\"150\">\n                                <div data-kid=\"151\">\n                                    <h3 class=\"text-2xl font-heading font-bold text-white tracking-wide\" data-kid=\"152\">CELAD</h3>\n                                    <p class=\"text-cyan-400 font-medium\" data-kid=\"153\">Ingénieur Développement</p>\n                                </div>\n                                <span class=\"px-4 py-1.5 rounded-full bg-white/5 text-cyan-100/60 text-sm font-semibold border border-white/10\" data-kid=\"154\">2010 – 2017</span>\n                            </div>\n                            <div class=\"grid md:grid-cols-2 gap-8\" data-kid=\"155\">\n                                <ul class=\"space-y-4\" data-kid=\"156\">\n                                    <li class=\"flex gap-4\" data-kid=\"157\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"158\"></i>\n                                        <span data-kid=\"159\"><strong class=\"text-white\" data-kid=\"160\">FRAM:</strong> B2B/B2C platforms, complex back-office development.</span>\n                                    </li>\n                                    <li class=\"flex gap-4\" data-kid=\"161\">\n                                        <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"162\"></i>\n                                        <span data-kid=\"163\"><strong class=\"text-white\" data-kid=\"164\">Europa Organisation:</strong> Hotel management application dev.</span>\n                                    </li>\n                                </ul>\n                                <div class=\"bg-cyan-950/40 rounded-2xl p-6 border border-cyan-500/10\" data-kid=\"165\">\n                                    <h4 class=\"text-xs uppercase tracking-widest text-cyan-400 mb-3 font-heading font-bold\" data-kid=\"166\">Tech Stack</h4>\n                                    <p class=\"text-xs text-cyan-100 leading-relaxed font-mono\" data-kid=\"167\">\n                                        PHP, Symfony 2, JQuery, Talend ETL, PostgreSQL, AngularJS.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative group\" data-kid=\"168\">\n                        <div class=\"absolute -left-[68px] top-2 w-7 h-7 rounded-full bg-[#001F3F] border-[3px] border-cyan-800/20 z-10\" data-kid=\"169\"></div>\n                        <div class=\"glass-card rounded-3xl p-8 hover:border-cyan-400/40 transition-all ml-4 opacity-60 hover:opacity-100\" data-kid=\"170\">\n                            <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6\" data-kid=\"171\">\n                                <div data-kid=\"172\">\n                                    <h3 class=\"text-2xl font-heading font-bold text-white tracking-wide\" data-kid=\"173\">PCKADO</h3>\n                                    <p class=\"text-cyan-400 font-medium\" data-kid=\"174\">Développeur informatique</p>\n                                </div>\n                                <span class=\"px-4 py-1.5 rounded-full bg-white/5 text-cyan-100/60 text-sm font-semibold border border-white/10\" data-kid=\"175\">2006 – 2009</span>\n                            </div>\n                            <div class=\"flex flex-col gap-4\" data-kid=\"176\">\n                                <li class=\"flex gap-4 list-none\" data-kid=\"177\">\n                                    <i class=\"ti ti-chevron-right text-cyan-500 mt-1\" data-kid=\"178\"></i>\n                                    <span data-kid=\"179\">Réalisation de fonctionnalités pour l'intranet et les sites internet de e-commerce de l'entreprise.</span>\n                                </li>\n                            </div>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"mb-24\" data-kid=\"180\">\n            <h2 class=\"text-4xl font-heading font-bold text-white mb-12 flex items-center gap-4\" data-kid=\"181\">\n                <i class=\"ti ti-award text-cyan-400\" data-kid=\"182\"></i> Certifications & Assets\n            </h2>\n            \n            <div class=\"masonry-grid\" data-kid=\"183\">\n                \n                \n                <div class=\"neon-inset rounded-3xl p-8\" data-kid=\"184\">\n                    <h3 class=\"text-2xl font-heading font-bold text-white mb-6 flex items-center gap-3\" data-kid=\"185\">\n                        <i class=\"ti ti-school text-cyan-400\" data-kid=\"186\"></i> Education\n                    </h3>\n                    <div class=\"space-y-6\" data-kid=\"187\">\n                        <div class=\"group\" data-kid=\"188\">\n                            <p class=\"font-bold text-cyan-100\" data-kid=\"189\">Angular - Découvrir le framework</p>\n                            <p class=\"text-sm text-cyan-400/60\" data-kid=\"190\">AELION Toulouse | 2021</p>\n                        </div>\n                        <div class=\"group\" data-kid=\"191\">\n                            <p class=\"font-bold text-cyan-100\" data-kid=\"192\">Symfony 2 Master</p>\n                            <p class=\"text-sm text-cyan-400/60\" data-kid=\"193\">Sensio Labs | 2014</p>\n                        </div>\n                        <div class=\"group\" data-kid=\"194\">\n                            <p class=\"font-bold text-cyan-100\" data-kid=\"195\">JAVA/J2EE Specialization</p>\n                            <p class=\"text-sm text-cyan-400/60\" data-kid=\"196\">CRP Consulting | 2009</p>\n                        </div>\n                        <div class=\"group\" data-kid=\"197\">\n                            <p class=\"font-bold text-cyan-100\" data-kid=\"198\">Diplôme de Recherche Univ.</p>\n                            <p class=\"text-sm text-cyan-400/60\" data-kid=\"199\">INP-ENSIACET | 2001</p>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass-card rounded-3xl p-8 relative overflow-hidden group\" data-kid=\"200\">\n                    <div class=\"absolute top-0 right-0 w-32 h-32 bg-cyan-400/5 rounded-full blur-3xl -mr-16 -mt-16\" data-kid=\"201\"></div>\n                    <h3 class=\"text-2xl font-heading font-bold text-white mb-6 flex items-center gap-3\" data-kid=\"202\">\n                        <i class=\"ti ti-sparkles text-cyan-400\" data-kid=\"203\"></i> Soft Skills\n                    </h3>\n                    <div class=\"flex flex-wrap gap-3\" data-kid=\"204\">\n                        <span class=\"px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"205\">Adaptabilité</span>\n                        <span class=\"px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"206\">Perfectionnisme</span>\n                        <span class=\"px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"207\">Rigueur</span>\n                        <span class=\"px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"208\">Leadership</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass-card rounded-3xl p-8\" data-kid=\"209\">\n                    <h3 class=\"text-2xl font-heading font-bold text-white mb-6 flex items-center gap-3\" data-kid=\"210\">\n                        <i class=\"ti ti-language text-cyan-400\" data-kid=\"211\"></i> Languages\n                    </h3>\n                    <div class=\"space-y-6\" data-kid=\"212\">\n                        <div data-kid=\"213\">\n                            <div class=\"flex justify-between items-center mb-2\" data-kid=\"214\">\n                                <span class=\"text-cyan-100 font-medium\" data-kid=\"215\">Français</span>\n                                <span class=\"text-xs text-cyan-400\" data-kid=\"216\">Maternelle</span>\n                            </div>\n                            <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"217\">\n                                <div class=\"h-full w-full bg-cyan-400\" data-kid=\"218\"></div>\n                            </div>\n                        </div>\n                        <div data-kid=\"219\">\n                            <div class=\"flex justify-between items-center mb-2\" data-kid=\"220\">\n                                <span class=\"text-cyan-100 font-medium\" data-kid=\"221\">Anglais</span>\n                                <span class=\"text-xs text-cyan-400\" data-kid=\"222\">Technique</span>\n                            </div>\n                            <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"223\">\n                                <div class=\"h-full w-[85%] bg-cyan-500/60\" data-kid=\"224\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n            </div>\n        </section>\n\n        \n        <div class=\"absolute bottom-8 right-6 flex flex-col gap-4 z-50\" data-kid=\"225\">\n            <button class=\"w-14 h-14 rounded-full glass-card flex items-center justify-center text-cyan-400 hover:bg-cyan-400 hover:text-[#001F3F] transition-all group shadow-xl cursor-pointer\" data-kid=\"226\">\n                <i class=\"ti ti-download text-2xl group-hover:scale-110 transition-transform\" data-kid=\"227\"></i>\n            </button>\n            <button class=\"w-14 h-14 rounded-full neon-inset flex items-center justify-center text-cyan-400 hover:scale-110 transition-all shadow-[0_0_20px_rgba(0,255,255,0.3)] cursor-pointer\" data-kid=\"228\">\n                <i class=\"ti ti-share text-2xl\" data-kid=\"229\"></i>\n            </button>\n        </div>\n\n        \n        <footer class=\"text-center py-12 border-t border-white/5\" data-kid=\"230\">\n            <p class=\"text-cyan-100/30 text-sm font-heading\" data-kid=\"231\">\n                © 2024 Jérôme CAPELLE • Crafted with Precision • Arctic Deep Space Edition\n            </p>\n        </footer>\n\n    </div>\n</div>\n",
