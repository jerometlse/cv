      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --sand: #EAE0C8;\n    --onyx: #111111;\n    --flame: #FF3800;\n  }\n\n  body {\n    background-color: var(--sand);\n    color: var(--onyx);\n    font-family: 'Space Grotesk', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n\n  .brutalist-container {\n    border: 8px solid var(--onyx);\n    position: relative;\n    background-color: var(--sand);\n  }\n\n  .texture-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-image: url('https://images.unsplash.com/photo-1616410731309-4e07df6b5d42?auto=format&w=1280&q=20&fit=crop');\n    background-size: cover;\n    opacity: 0.1;\n    pointer-events: none;\n    z-index: 50;\n  }\n\n  .hard-offset {\n    box-shadow: 12px 12px 0px 0px var(--onyx);\n  }\n\n  .hard-offset-sm {\n    box-shadow: 6px 6px 0px 0px var(--onyx);\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n\n  .marquee-content {\n    animation: marquee 30s linear infinite;\n    display: flex;\n    width: max-content;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .duotone-filter {\n    filter: grayscale(100%) contrast(1.1) brightness(1.1);\n  }\n\n  .staircase-stack > div {\n    margin-top: -1.5rem;\n    position: relative;\n    z-index: 10;\n  }\n  .staircase-stack > div:first-child { margin-top: 0; }\n\n  .notch-tag {\n    clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 15% 100%, 0% 50%);\n    padding-left: 2rem;\n  }\n\n  .highlight-flame {\n    background-color: var(--flame);\n    color: white;\n    padding: 0 0.25rem;\n  }\n</style>\n\n<div class=\"min-h-[1400px] w-full p-8 md:p-12 bg-white flex justify-center\" data-kid=\"1\">\n  <div class=\"w-full max-w-[1280px] brutalist-container overflow-hidden relative\" data-kid=\"2\">\n    <div class=\"texture-overlay\" data-kid=\"3\"></div>\n    \n    \n    <header class=\"relative grid grid-cols-12 gap-0 border-b-8 border-[var(--onyx)] min-h-[500px]\" data-kid=\"4\">\n      \n      <div class=\"absolute top-8 left-8 z-20\" data-kid=\"5\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/black-bar.svg\" class=\"w-24 h-8 opacity-40\" alt=\"barcode decoration\" data-kid=\"6\">\n      </div>\n\n      <div class=\"col-span-8 p-12 flex flex-col justify-end bg-[var(--sand)] relative\" data-kid=\"7\">\n        \n        <div class=\"absolute -top-10 -left-6 bg-[var(--onyx)] p-10 transform -rotate-2 z-10\" data-kid=\"8\">\n          <h1 class=\"font-anton text-[140px] leading-[0.8] text-[var(--sand)] uppercase tracking-tighter\" data-kid=\"9\">\n            JÉRÔME<br data-kid=\"10\">CAPELLE\n          </h1>\n        </div>\n        \n        <div class=\"mt-[280px]\" data-kid=\"11\">\n          <h2 class=\"font-anton text-4xl uppercase tracking-widest border-b-4 border-onyx pb-2 inline-block\" data-kid=\"12\">\n            Ingénieur Full Stack\n          </h2>\n          <div class=\"mt-8 text-2xl max-w-2xl font-medium leading-tight\" data-kid=\"13\">\n            <p data-kid=\"14\">\n              Expert avec <span class=\"highlight-flame\" data-kid=\"15\">15 ans d'expérience</span> dans la conception d'applications web critiques. \n              Spécialisé en architectures backend (<span class=\"highlight-flame\" data-kid=\"16\">Python / Django</span>, Symfony) \n              et interfaces modernes (<span class=\"highlight-flame\" data-kid=\"17\">Vue.js / Nuxt</span>) pour de grands comptes.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"col-span-4 bg-[var(--onyx)] p-12 flex items-center justify-center relative\" data-kid=\"18\">\n        \n        <div class=\"w-full max-w-[320px] aspect-[4/5] bg-[var(--sand)] border-4 border-[var(--onyx)] hard-offset relative overflow-hidden group\" data-kid=\"19\">\n          <img src=\"/api/local/images/portrait.jpg\" class=\"w-full h-full object-cover duotone-filter\" alt=\"Portrait\" decoding=\"async\" loading=\"lazy\" data-kid=\"20\">\n          \n          <div class=\"absolute bottom-8 -right-4 bg-[var(--flame)] text-white font-anton px-6 py-1 text-2xl transform rotate-[-12deg] border-2 border-[var(--onyx)] shadow-[4px_4px_0_#111] z-30\" data-kid=\"21\">\n            15Y EXP\n          </div>\n        </div>\n        \n        <img src=\"https://images.unsplash.com/photo-1522151656182-013606406818?auto=format&w=400&q=20&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-5 pointer-events-none\" alt=\"decoration\" data-kid=\"22\">\n      </div>\n    </header>\n\n    \n    <div class=\"bg-[var(--flame)] border-b-8 border-[var(--onyx)] py-4 overflow-hidden relative\" data-kid=\"23\">\n      <div class=\"marquee-content whitespace-nowrap\" data-kid=\"24\">\n        <div class=\"flex items-center gap-12 font-anton text-4xl text-white uppercase italic\" data-kid=\"25\">\n          <span data-kid=\"26\">Django • Symfony • Vue.js • Nuxt • PostgreSQL • Docker • Google Cloud • Git • </span>\n          <span data-kid=\"27\">Django • Symfony • Vue.js • Nuxt • PostgreSQL • Docker • Google Cloud • Git • </span>\n          <span data-kid=\"28\">Django • Symfony • Vue.js • Nuxt • PostgreSQL • Docker • Google Cloud • Git • </span>\n          <span data-kid=\"29\">Django • Symfony • Vue.js • Nuxt • PostgreSQL • Docker • Google Cloud • Git • </span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-4 border-b-8 border-[var(--onyx)] bg-[var(--onyx)] text-[var(--sand)]\" data-kid=\"30\">\n      <div class=\"border-r-4 border-[var(--sand)]/20 p-6 flex flex-col justify-center\" data-kid=\"31\">\n        <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] text-[var(--flame)] mb-1\" data-kid=\"32\">Localisation</span>\n        <span class=\"text-base font-bold\" data-kid=\"33\">GRAGNAGUE (31), FR</span>\n      </div>\n      <div class=\"border-r-4 border-[var(--sand)]/20 p-6 flex flex-col justify-center\" data-kid=\"34\">\n        <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] text-[var(--flame)] mb-1\" data-kid=\"35\">Téléphone</span>\n        <span class=\"text-base font-bold\" data-kid=\"36\">06 16 49 40 25</span>\n      </div>\n      <div class=\"border-r-4 border-[var(--sand)]/20 p-6 flex flex-col justify-center overflow-hidden\" data-kid=\"37\">\n        <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] text-[var(--flame)] mb-1\" data-kid=\"38\">Email</span>\n        <span class=\"text-sm font-bold truncate\" data-kid=\"39\">JEROME.CAPELLE@GMAIL.COM</span>\n      </div>\n      <div class=\"p-6 flex flex-col justify-center\" data-kid=\"40\">\n        <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] text-[var(--flame)] mb-1\" data-kid=\"41\">Détails</span>\n        <div class=\"flex items-center gap-4\" data-kid=\"42\">\n          <span class=\"text-base font-bold uppercase\" data-kid=\"43\">50 ANS • PERMIS B</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-12 min-h-[800px]\" data-kid=\"44\">\n      \n      \n      <main class=\"col-span-8 p-12 border-r-8 border-onyx\" data-kid=\"45\">\n        <div class=\"flex items-center gap-4 mb-16\" data-kid=\"46\">\n          <h2 class=\"font-anton text-6xl uppercase leading-none bg-onyx text-sand px-6 py-2\" data-kid=\"47\">Expériences</h2>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bottom-right-3d-arrow.svg\" class=\"w-16 h-16 text-onyx\" style=\"color: #111;\" alt=\"arrow decoration\" data-kid=\"48\">\n        </div>\n\n        <div class=\"staircase-stack\" data-kid=\"49\">\n          \n          <div class=\"z-30 bg-[var(--sand)] border-4 border-[var(--onyx)] p-8 hard-offset group hover:translate-x-2 transition-transform\" data-kid=\"50\">\n            <div class=\"flex justify-between items-start mb-6\" data-kid=\"51\">\n              <div data-kid=\"52\">\n                <h3 class=\"font-anton text-4xl uppercase\" data-kid=\"53\">CCL CONSULTING</h3>\n                <p class=\"text-xl font-bold text-[var(--flame)]\" data-kid=\"54\">Ingénieur Full Stack | 2020 – Aujourd'hui</p>\n              </div>\n              <div class=\"text-right flex flex-col items-end\" data-kid=\"55\">\n                <span class=\"bg-[var(--onyx)] text-[var(--sand)] px-3 py-1 text-[10px] font-bold uppercase mb-2\" data-kid=\"56\">SAFRAN • GUIDAP • AIRBUS</span>\n                <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/snowflake-2.svg\" class=\"w-8 h-8 opacity-20\" alt=\"decoration\" data-kid=\"57\">\n              </div>\n            </div>\n            <ul class=\"space-y-4 text-lg border-l-4 border-onyx pl-6 mb-8\" data-kid=\"58\">\n              <li data-kid=\"59\">\n                <strong class=\"italic\" data-kid=\"60\">Safran Ventilation Systems</strong> — Développement d'une application critique de calcul de fiabilité.\n              </li>\n              <li data-kid=\"61\">\n                <strong class=\"italic\" data-kid=\"62\">Guidap</strong> — Maintenance et évolution d'une plateforme d'activités de plein air (PHP/Symfony).\n              </li>\n              <li data-kid=\"63\">\n                <strong class=\"italic\" data-kid=\"64\">Airbus</strong> — Automatisation de la gestion du cycle de vie des comptes collaborateur (Python/G Suite).\n              </li>\n            </ul>\n            <div class=\"flex flex-wrap gap-2 mt-4\" data-kid=\"65\">\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"66\">Python</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"67\">Django</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"68\">Vue.js</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"69\">Nuxt</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"70\">PostgreSQL</span>\n            </div>\n          </div>\n\n          \n          <div class=\"z-20 bg-sand border-4 border-onyx p-8 hard-offset ml-8 group hover:translate-x-2 transition-transform\" data-kid=\"71\">\n            <div class=\"flex justify-between items-start mb-6\" data-kid=\"72\">\n              <div data-kid=\"73\">\n                <h3 class=\"font-anton text-4xl uppercase\" data-kid=\"74\">DÉCASOFT</h3>\n                <p class=\"text-xl font-bold text-flame\" data-kid=\"75\">Ingénieur d'études | 2017 – 2020</p>\n              </div>\n              <span class=\"bg-onyx text-sand px-3 py-1 text-sm font-bold uppercase h-fit\" data-kid=\"76\">AIRBUS • WS-INTERACTIVE</span>\n            </div>\n            <p class=\"text-lg border-l-4 border-onyx pl-6 mb-8 italic\" data-kid=\"77\">\n              Développement et maintenance de plusieurs sites internet critiques pour grands comptes industriels.\n            </p>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"78\">\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"79\">PHP</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"80\">Symfony</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"81\">Python</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"82\">Angular</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"83\">RabbitMQ</span>\n            </div>\n          </div>\n\n          \n          <div class=\"z-10 bg-sand border-4 border-onyx p-8 hard-offset ml-16 group hover:translate-x-2 transition-transform\" data-kid=\"84\">\n            <div class=\"flex justify-between items-start mb-6\" data-kid=\"85\">\n              <div data-kid=\"86\">\n                <h3 class=\"font-anton text-4xl uppercase\" data-kid=\"87\">CELAD</h3>\n                <p class=\"text-xl font-bold text-flame\" data-kid=\"88\">Ingénieur Développement | 2010 – 2017</p>\n              </div>\n              <span class=\"bg-onyx text-sand px-3 py-1 text-sm font-bold uppercase h-fit\" data-kid=\"89\">FRAM • EUROPA • LATECOERE</span>\n            </div>\n            <p class=\"text-lg border-l-4 border-onyx pl-6 mb-8 italic\" data-kid=\"90\">\n              Développement de back-offices complexes, gestion de flux de données via Talend, plateformes B2B/B2C.\n            </p>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"91\">\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"92\">Symfony 1.4/2</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"93\">Talend ETL</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"94\">AngularJS</span>\n              <span class=\"border-2 border-onyx px-3 py-1 font-bold text-sm bg-white uppercase\" data-kid=\"95\">JQuery</span>\n            </div>\n          </div>\n        </div>\n      </main>\n\n      \n      <aside class=\"col-span-4 bg-white flex flex-col\" data-kid=\"96\">\n        \n        \n        <section class=\"p-10 border-b-8 border-[var(--onyx)] bg-[var(--sand)] flex-1 relative overflow-hidden\" data-kid=\"97\">\n          <div class=\"absolute -top-4 -right-4 opacity-5 pointer-events-none\" data-kid=\"98\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/black-bar.svg\" class=\"w-32 h-12 transform rotate-90\" alt=\"deco\" data-kid=\"99\">\n          </div>\n          <h2 class=\"font-anton text-5xl uppercase mb-10 underline decoration-[var(--flame)] decoration-8\" data-kid=\"100\">Arsenal</h2>\n          \n          <div class=\"space-y-6 relative z-10\" data-kid=\"101\">\n            <div class=\"bg-white border-4 border-[var(--onyx)] p-4 hard-offset-sm transform rotate-1 hover:translate-x-1 transition-transform cursor-default\" data-kid=\"102\">\n              <div class=\"flex items-center gap-3 mb-2\" data-kid=\"103\">\n                <i class=\"ti ti-terminal text-[var(--flame)] text-2xl\" data-kid=\"104\"></i>\n                <h3 class=\"font-anton text-xl uppercase text-[var(--onyx)]\" data-kid=\"105\">Backend</h3>\n              </div>\n              <p class=\"text-[var(--onyx)] font-bold text-sm\" data-kid=\"106\">Python (Django), PHP (Symfony 3/4).</p>\n            </div>\n\n            <div class=\"bg-white border-4 border-[var(--onyx)] p-4 hard-offset-sm transform -rotate-1 hover:translate-x-1 transition-transform cursor-default\" data-kid=\"107\">\n              <div class=\"flex items-center gap-3 mb-2\" data-kid=\"108\">\n                <i class=\"ti ti-layout text-[var(--flame)] text-2xl\" data-kid=\"109\"></i>\n                <h3 class=\"font-anton text-xl uppercase text-[var(--onyx)]\" data-kid=\"110\">Frontend</h3>\n              </div>\n              <p class=\"text-[var(--onyx)] font-bold text-sm\" data-kid=\"111\">Vue.js, Nuxt, Angular, Tailwind CSS.</p>\n            </div>\n\n            <div class=\"bg-white border-4 border-[var(--onyx)] p-4 hard-offset-sm transform rotate-1 hover:translate-x-1 transition-transform cursor-default\" data-kid=\"112\">\n              <div class=\"flex items-center gap-3 mb-2\" data-kid=\"113\">\n                <i class=\"ti ti-database text-[var(--flame)] text-2xl\" data-kid=\"114\"></i>\n                <h3 class=\"font-anton text-xl uppercase text-[var(--onyx)]\" data-kid=\"115\">Data</h3>\n              </div>\n              <p class=\"text-[var(--onyx)] font-bold text-sm\" data-kid=\"116\">PostgreSQL, MSSQL, MariaDB, Talend.</p>\n            </div>\n\n            <div class=\"bg-white border-4 border-[var(--onyx)] p-4 hard-offset-sm transform -rotate-1 hover:translate-x-1 transition-transform cursor-default\" data-kid=\"117\">\n              <div class=\"flex items-center gap-3 mb-2\" data-kid=\"118\">\n                <i class=\"ti ti-cloud text-[var(--flame)] text-2xl\" data-kid=\"119\"></i>\n                <h3 class=\"font-anton text-xl uppercase text-[var(--onyx)]\" data-kid=\"120\">Cloud / Ops</h3>\n              </div>\n              <p class=\"text-[var(--onyx)] font-bold text-sm\" data-kid=\"121\">Google Cloud (GCP), Docker, G Suite APIs.</p>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"p-10 bg-[var(--onyx)] text-[var(--sand)]\" data-kid=\"122\">\n          <div class=\"mb-12\" data-kid=\"123\">\n            <h2 class=\"font-anton text-4xl uppercase mb-8 text-[var(--flame)] italic underline\" data-kid=\"124\">Formation</h2>\n            <div class=\"space-y-6\" data-kid=\"125\">\n              <div class=\"border-l-4 border-[var(--flame)] pl-4\" data-kid=\"126\">\n                <h4 class=\"font-bold uppercase text-xs\" data-kid=\"127\">Angular Framework</h4>\n                <p class=\"text-[10px] text-[var(--sand)]/60\" data-kid=\"128\">AELION | 2021</p>\n              </div>\n              <div class=\"border-l-4 border-[var(--flame)] pl-4\" data-kid=\"129\">\n                <h4 class=\"font-bold uppercase text-xs\" data-kid=\"130\">Symfony 2</h4>\n                <p class=\"text-[10px] text-[var(--sand)]/60\" data-kid=\"131\">SENSIO LABS | 2014</p>\n              </div>\n              <div class=\"border-l-4 border-[var(--flame)] pl-4\" data-kid=\"132\">\n                <h4 class=\"font-bold uppercase text-xs\" data-kid=\"133\">DRU / Maîtrise Chimie</h4>\n                <p class=\"text-[10px] text-[var(--sand)]/60\" data-kid=\"134\">UPS TOULOUSE | 2000-2001</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"relative\" data-kid=\"135\">\n            <div class=\"absolute -bottom-8 -right-8 opacity-10 pointer-events-none\" data-kid=\"136\">\n               <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/middle-arrow.svg\" class=\"w-32 h-32 transform -rotate-45\" alt=\"deco\" data-kid=\"137\">\n            </div>\n            <h2 class=\"font-anton text-4xl uppercase mb-8 text-[var(--flame)] italic underline\" data-kid=\"138\">Personnalité</h2>\n            <div class=\"space-y-4 relative z-10\" data-kid=\"139\">\n              <div class=\"notch-tag bg-[var(--sand)] text-[var(--onyx)] font-anton py-2 pr-4 text-xl tracking-tighter transform hover:scale-105 transition-transform\" data-kid=\"140\">ADAPTABILITÉ</div>\n              <div class=\"notch-tag bg-[var(--sand)] text-[var(--onyx)] font-anton py-2 pr-4 text-xl tracking-tighter transform hover:scale-105 transition-transform\" data-kid=\"141\">PERFECTIONNISME</div>\n              <div class=\"notch-tag bg-[var(--sand)] text-[var(--onyx)] font-anton py-2 pr-4 text-xl tracking-tighter transform hover:scale-105 transition-transform\" data-kid=\"142\">RIGUEUR</div>\n            </div>\n          </div>\n\n          <div class=\"mt-12 pt-12 border-t-4 border-[var(--sand)]/20\" data-kid=\"143\">\n            <h2 class=\"font-anton text-4xl uppercase mb-6 text-[var(--flame)] italic underline\" data-kid=\"144\">Langues</h2>\n            <div class=\"space-y-2 font-bold uppercase text-sm\" data-kid=\"145\">\n              <div class=\"flex justify-between items-center\" data-kid=\"146\">\n                <span data-kid=\"147\">Français</span>\n                <span class=\"text-[var(--flame)]\" data-kid=\"148\">Maternelle</span>\n              </div>\n              <div class=\"flex justify-between items-center\" data-kid=\"149\">\n                <span data-kid=\"150\">Anglais</span>\n                <span class=\"text-[var(--flame)]\" data-kid=\"151\">Technique</span>\n              </div>\n            </div>\n          </div>\n        </section>\n      </aside>\n\n    </div>\n\n    \n    <footer class=\"bg-[var(--onyx)] border-t-8 border-[var(--onyx)] p-12 flex justify-between items-end text-[var(--sand)] relative overflow-hidden\" data-kid=\"152\">\n      \n      <div class=\"absolute top-0 left-0 w-full h-full pointer-events-none opacity-5 flex items-center justify-around\" data-kid=\"153\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/branch-arrow.svg\" class=\"w-64 h-64\" alt=\"deco\" data-kid=\"154\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/branch-arrow.svg\" class=\"w-64 h-64 transform rotate-180\" alt=\"deco\" data-kid=\"155\">\n      </div>\n\n      <div class=\"z-10\" data-kid=\"156\">\n        <h4 class=\"font-anton text-7xl uppercase tracking-tighter leading-none mb-4\" data-kid=\"157\">INGÉNIEUR<br data-kid=\"158\">FULL STACK</h4>\n        <p class=\"font-bold text-[var(--flame)] tracking-widest uppercase\" data-kid=\"159\">© Jérôme Capelle 2024</p>\n      </div>\n\n      <div class=\"z-10 text-right\" data-kid=\"160\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/black-bar.svg\" class=\"w-48 h-16 ml-auto filter invert brightness-[5]\" alt=\"barcode decoration\" data-kid=\"161\">\n        <p class=\"mt-4 font-bold text-[var(--sand)]/40\" data-kid=\"162\">SCANNED SYSTEM 0101-FR</p>\n      </div>\n    </footer>\n\n  </div>\n</div>\n",
